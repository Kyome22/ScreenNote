    "mailBody" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "# Umgebung\n- %@: ver %@\n- %@\n- macOS: %@\n\n# Was Sie versucht haben\n- App neu gestartet: Ja/Nein\n- App deinstalliert: Ja/Nein\n\n# Kurzbeschreibung\n\n\n# Schritte zur Reproduktion des Problems\n\n\n# Erwartetes Ergebnis\n\n"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "# Environment\n- %@: ver %@\n- %@\n- macOS: %@\n\n# What You Tried\n- Relaunched the app: Yes/No\n- Uninstalled the app: Yes/No\n\n# Short Description\n\n\n# Steps to Reproduce the Issue\n\n\n# Expected Result\n\n"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "# Entorno\n- %@: ver %@\n- %@\n- macOS: %@\n\n# Lo que has probado\n- Reiniciar la app: Sí/No\n- Desinstalar la app: Sí/No\n\n# Descripción breve\n\n\n# Pasos para reproducir el problema\n\n\n# Resultado esperado\n\n"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "# Environnement\n- %@ : ver %@\n- %@\n- macOS : %@\n\n# Ce que vous avez essayé\n- Relancement de l’app : Oui/Non\n- Désinstallation de l’app : Oui/Non\n\n# Brève description\n\n\n# Étapes pour reproduire le problème\n\n\n# Résultat attendu\n\n"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "# 環境\n- %@: ver %@\n- %@\n- macOS: %@\n\n# 試したこと\n- アプリの再起動：はい/いいえ\n- アプリのアンインストール：はい/いいえ\n\n# 不具合の簡単な説明\n\n\n# 不具合の再現手順（不具合が発生した際に行なっていた操作）\n\n\n# 本来期待される挙動\n\n"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "# 환경\n- %@: ver %@\n- %@\n- macOS: %@\n\n# 시도한 것\n- 앱 재실행: 예/아니오\n- 앱 제거: 예/아니오\n\n# 간단한 설명\n\n\n# 문제 재현 단계\n\n\n# 기대했던 결과\n\n"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "# 环境\n- %@: ver %@\n- %@\n- macOS: %@\n\n# 您尝试过的操作\n- 重新启动应用: 是/否\n- 卸载应用: 是/否\n\n# 简短描述\n\n\n# 问题重现步骤\n\n\n# 期望的结果\n\n"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "# 環境\n- %@: ver %@\n- %@\n- macOS: %@\n\n# 您嘗試過的操作\n- 重新啟動應用程式: 是/否\n- 解除安裝應用程式: 是/否\n\n# 簡短描述\n\n\n# 問題重現步驟\n\n\n# 預期結果\n\n"
          }
        }
      }
    },

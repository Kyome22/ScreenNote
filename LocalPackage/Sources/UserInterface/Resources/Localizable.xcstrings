    "donationDescription" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ScreenNote stellt allen sämtliche Funktionen kostenlos zur Verfügung.\nSie können dieses Projekt unterstützen, indem Sie eine heiße Schokolade spendieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ScreenNote provides all features for free to everyone.\nYou can support this project by offering hot cocoa."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ScreenNote ofrece todas sus funciones gratis a todo el mundo.\nPuedes apoyar este proyecto invitando a un chocolate caliente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ScreenNote propose toutes ses fonctionnalités gratuitement à tous.\nVous pouvez soutenir ce projet en offrant un chocolat chaud."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ScreenNote はすべての機能を無償で提供しています。\nココアを贈ることでこのプロジェクトをサポートできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ScreenNote는 모든 기능을 무료로 제공합니다.\n핫코코아를 보내 이 프로젝트를 후원할 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ScreenNote 免费向所有人提供全部功能。\n您可以通过赠送热可可来支持本项目。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ScreenNote 免費為所有人提供全部功能。\n您可以透過贈送熱可可來支持本專案。"
          }
        }
      }
    },
